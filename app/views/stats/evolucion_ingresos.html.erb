<%
  historical_data_size = HISTORICAL_INCOME_DATA.size
  start_date = I18n.l(1.year.ago.to_date, format: "%b %Y")

  # Pre-procesar los labels para el eje X
  x_axis_labels = @chart_data[:labels].map { |label| label.to_s.gsub(' ', '\n') }
%>

<div class="container mt-5">
  <h2>Evolución de Ingresos (Histórico + Actual)</h2>

  <div data-controller="echart-evolucion"
       data-echart-evolucion-labels-value='<%= x_axis_labels.to_json %>'
       data-echart-evolucion-values-value='<%= @chart_data[:values].to_json %>'
       data-echart-evolucion-historical-value='<%= @chart_data[:is_historical].to_json %>'
       style="width: 100%; height: 600px; margin-top: 20px;">
    <div class="text-center py-5">
      <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Cargando gráfico...</span>
      </div>
    </div>
  </div>
</div>
