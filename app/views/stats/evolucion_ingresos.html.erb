<%# app/views/comun/inicio.html.erb %>
<%
  historical_data_size = HISTORICAL_INCOME_DATA.size
  start_date = I18n.l(1.year.ago.to_date, format: "%b %Y")
  
  # Pre-procesar los labels para el eje X con saltos de línea
  x_axis_labels = @chart_data[:labels].map do |label|
    parts = label.to_s.split(' ')
    parts.size > 1 ? "#{parts[0]}\n#{parts[1]}" : label.to_s
  end
%>

<div data-controller="echart"
     data-echart-options='<%= {
       title: {
         text: "Evolución de Ingresos (Histórico + Actual)",
         left: 'center',
         textStyle: {
           fontSize: 18,
           fontWeight: 'bold'
         }
       },
       tooltip: {
         trigger: 'axis',
         formatter: {
           formatter: "function(params) {
             var date = params[0].axisValue;
             var amount = params[0].value.toLocaleString('es-ES', {style: 'currency', currency: 'EUR'});
             var type = params[0].dataIndex < #{historical_data_size} ? 'Histórico' : 'Actual';
             return date + '<br/>' + amount + '<br/><small>' + type + '</small>';
           }"
         }
       },
       legend: {
         data: ['Histórico', 'Actual'],
         right: 20
       },
       xAxis: {
         type: "category",
         data: x_axis_labels,
         axisLabel: {
           rotate: 45
         },
         axisPointer: {
           label: {
             formatter: {
               formatter: "function(params) {
                 return params.value.replace(/\\n/g, ' ');
               }"
             }
           }
         }
       },
       yAxis: {
         type: "value",
         axisLabel: {
           formatter: '{value} €'
         },
         splitLine: {
           lineStyle: {
             type: 'dashed'
           }
         }
       },
       series: [{
         name: 'Histórico',
         type: 'line',
         data: @chart_data[:values].each_with_index.map { |v, i| @chart_data[:is_historical][i] ? v : nil },
         symbol: 'circle',
         symbolSize: 6,
         lineStyle: {
           width: 2,
           color: '#7b9ce1'
         },
         itemStyle: {
           color: '#7b9ce1'
         },
         emphasis: {
           itemStyle: {
             color: '#3a4de9'
           }
         }
       }, {
         name: 'Actual',
         type: 'line',
         data: @chart_data[:values].each_with_index.map { |v, i| @chart_data[:is_historical][i] ? nil : v },
         symbol: 'circle',
         symbolSize: 8,
         lineStyle: {
           width: 3,
           color: '#4CAF50'
         },
         itemStyle: {
           color: '#4CAF50'
         },
         emphasis: {
           itemStyle: {
             color: '#2E7D32'
           }
         },
         markPoint: {
           data: [
             { type: 'max', name: 'Máximo' },
             { type: 'min', name: 'Mínimo' }
           ]
         }
       }],
       dataZoom: [{
         type: 'inside',
         startValue: start_date
       }, {
         start: 70,
         end: 100
       }],
       grid: {
         top: '15%',
         right: '5%',
         left: '5%',
         bottom: '20%',
         containLabel: true
       }
     }.to_json %>'
     style="width: 100%; height: 600px; margin-top: 20px;">
</div>
