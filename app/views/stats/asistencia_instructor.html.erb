<section class="container mt-4">
  <div class="row">
    <div class="col-12">
      <div class="card">
        <div class="card-header bg-primary text-white">
          <h5 class="mb-0">
            <i class="bi bi-person-badge me-2"></i>
            Asistencia por Instructor - <%= @instructor.nombre if @instructor %> - <%= @mes_nombre %>
          </h5>
        </div>
        <div class="card-body">
          <% if @instructor && @attendance_data %>
            <div class="table-responsive">
              <table class="table table-striped">
                <thead>
                  <tr>
                    <th>Día</th>
                    <th>Total Clases</th>
                    <th>Asistencias</th>
                    <th>Tasa Asistencia</th>
                  </tr>
                </thead>
                <tbody>
                  <% @attendance_data.each do |data| %>
                    <tr>
                      <td><%= data[:dia] %></td>
                      <td><%= data[:total] %></td>
                      <td><%= data[:attended] %></td>
                      <td>
                        <span class="badge bg-<%= data[:rate] >= 80 ? 'success' : data[:rate] >= 60 ? 'warning' : 'danger' %>">
                          <%= data[:rate] %>%
                        </span>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <p class="text-muted">Selecciona un instructor para ver las estadísticas.</p>
          <% end %>
          
          <%= link_to '← Volver al Panel', comun_michon_path, class: 'btn btn-secondary mt-3' %>
        </div>
      </div>
    </div>
  </div>
</section>
