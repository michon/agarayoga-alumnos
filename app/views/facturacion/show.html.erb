<%# app/views/facturacion/show.html.erb %>
<div class="container mt-4">

  <%# Cabecera mejorada con resumen integrado %>
    <div class="card border-primary border-1 mb-4">
      <div class="card-body bg-light">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h2 class="mb-0 text-primary"><i class="bi bi-building me-2"></i>Gestión Fiscal <%= @trimestre %></h2>
            <small class="text-muted">Trimestre <%= @numero %> del año <%= @anio %></small>
          </div>
          <div class="text-end">
            <h3 class="mb-0 text-primary"><%= number_to_currency(@resumen[:ventas] + @resumen[:abonos], unit: '€') %></h3>
            <small class="text-muted"><%= @resumen[:total] %> facturas</small>
          </div>
        </div>

        <%# Mini resumen %>
        <div class="row mt-3 pt-3 border-top">
          <div class="col-md-3 text-center">
            <i class="bi bi-file-earmark-text fs-4 d-block mb-1 text-primary"></i>
            <span class="fs-5 fw-bold"><%= @resumen[:total] %></span>
            <small class="d-block text-muted">Total</small>
          </div>
          <div class="col-md-3 text-center">
            <i class="bi bi-check-circle-fill fs-4 d-block mb-1 text-success"></i>
            <span class="fs-5 fw-bold"><%= @resumen[:emitidas] %></span>
            <small class="d-block text-muted">Emitidas</small>
          </div>
          <div class="col-md-3 text-center">
            <i class="bi bi-pencil-square fs-4 d-block mb-1 text-warning"></i>
            <span class="fs-5 fw-bold"><%= @resumen[:borradores] %></span>
            <small class="d-block text-muted">Borradores</small>
          </div>
          <div class="col-md-3 text-center">
            <i class="bi bi-bank fs-4 d-block mb-1 text-primary"></i>
            <span class="fs-5 fw-bold"><%= number_to_currency(@resumen[:ventas] + @resumen[:abonos], unit: '') %></span>
            <small class="d-block text-muted">Base Hacienda</small>
          </div>
        </div>
      </div>
    </div>

  <%# Alertas %>
  <% if flash[:notice] %>
    <div class="alert alert-success"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="alert alert-danger"><%= flash[:alert] %></div>
  <% end %>

  <%# Acciones %>
  <div class="row mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h5><i class="bi bi-gear me-2"></i>Acciones</h5>
        </div>
        <div class="card-body">
          <% if @resumen[:total] == 0 %>
            <%= button_to "Generar Borradores",
                          generar_facturacion_path(@trimestre),
                          method: :post,
                          class: "btn btn-primary",
                          data: { confirm: "¿Generar facturas en borrador para #{@trimestre}?" } %>
                        <%# En la sección de acciones, cuando hay borradores %>
          <% elsif @resumen[:borradores] > 0 %>

            <%# Validación: recibos de Serie A sin factura %>
            <% recibos_sin_factura = Recibo.where(serie: 'A', factura_id: nil)
                                            .where(vencimiento: @inicio..@fin)
                                            .where(reciboEstado_id: [2, 3]) %>

            <% if recibos_sin_factura.any? %>
              <div class="alert alert-warning mb-3">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Atención:</strong> Hay <%= recibos_sin_factura.count %> recibos de Serie A sin facturar en este trimestre.
                <%= link_to "Ver recibos pendientes", "#", class: "alert-link", data: { bs_toggle: "collapse", bs_target: "#recibos-pendientes" } %>
              </div>

              <div id="recibos-pendientes" class="collapse mb-3">
                <div class="card card-body bg-light">
                  <h6>Recibos de Serie A pendientes de facturar:</h6>
                  <ul class="list-unstyled mb-0">
                    <% recibos_sin_factura.limit(10).each do |recibo| %>
                      <li>
                        <code>rcb-<%= recibo.id %></code> -
                        <%= recibo.usuario&.nombre || "Sin nombre" %> -
                        <%= number_to_currency(recibo.importe, unit: '€') %> -
                        <% if recibo.remesa_id %>
                          <span class="badge bg-info">Remesado</span>
                        <% else %>
                          <span class="badge bg-warning text-dark">Sin remesa (bizum?)</span>
                        <% end %>
                      </li>
                    <% end %>
                    <% if recibos_sin_factura.count > 10 %>
                      <li class="text-muted">... y <%= recibos_sin_factura.count - 10 %> más</li>
                    <% end %>
                  </ul>
                  <div class="mt-2">
                    <%= link_to "Generar facturas para estos recibos",
                                generar_facturacion_path(@trimestre),
                                method: :post,
                                class: "btn btn-sm btn-warning",
                                data: { confirm: "¿Generar facturas para los recibos pendientes?" } %>
                  </div>
                </div>
              </div>
            <% end %>

            <div class="btn-group" role="group">
              <%# Reemplaza el botón de emitir por esto: %>
              <button type="button" class="btn btn-success" onclick="abrirVerificacion('<%= verificar_emision_facturacion_path(@trimestre) %>')">
                <i class="bi bi-shield-check me-1"></i>
                Verificar y Emitir (<%= @resumen[:borradores] %>)
              </button>
              <%= button_to "Limpiar Borradores",
                            limpiar_facturacion_path(@trimestre),
                            method: :delete,
                            class: "btn btn-outline-danger ms-2",
                            data: { confirm: "¿Eliminar los borradores y empezar de nuevo?" } %>
            </div>

            <% if @resumen[:emitidas] > 0 %>
              <div class="alert alert-info mt-3">
                Ya hay <%= @resumen[:emitidas] %> facturas emitidas en este trimestre.
              </div>
            <% end %>
          <% else %>
            <div class="alert alert-info mb-0">
              <i class="bi bi-check-circle me-2"></i>Trimestre cerrado y emitido.
              <div class="mt-2">
                <%= link_to exportar_facturacion_path(@trimestre, format: :xlsx), class: "btn btn-sm btn-outline-primary" do %>
                  <i class="bi bi-file-earmark-excel me-1"></i>Excel
                <% end %>
                <%= link_to exportar_facturacion_path(@trimestre, format: :ods), class: "btn btn-sm btn-outline-primary ms-2" do %>
                  <i class="bi bi-file-earmark-spreadsheet me-1"></i>ODS
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>


<%# Añade esto antes de la lista de facturas %>
<div class="row mb-3">
  <div class="col-12">
    <div class="btn-group" role="group">
      <span class="btn btn-outline-secondary disabled">Ordenar por:</span>
      <%= sort_link(@q, :numero, "Nº Factura", class: "btn btn-outline-primary") %>
      <%= sort_link(@q, :fecha_emision, "Fecha", class: "btn btn-outline-primary") %>
      <%= sort_link(@q, :recibo_usuario_nombre, "Alumno", class: "btn btn-outline-primary") %>
      <%= sort_link(@q, :total, "Importe", class: "btn btn-outline-primary") %>
    </div>
  </div>
</div>


  <%# Filtros para facturas %>
  <div class="row mt-4 mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-header">
          <h5><i class="bi bi-funnel me-2"></i>Filtrar y Revisar</h5>
        </div>
        <div class="card-body">
          <%= search_form_for @q, url: facturacion_trimestre_path(@trimestre), method: :get do |f| %>
            <div class="row g-3">
              <%# Nombre del alumno %>
              <div class="col-md-3">
                <%= f.label :recibo_usuario_nombre_cont, "Nombre alumno", class: "form-label" %>
                <%= f.search_field :recibo_usuario_nombre_cont, 
                    class: "form-control", 
                    placeholder: "Buscar por nombre...",
                    value: params.dig(:q, :recibo_usuario_nombre_cont) %>
              </div>
              
              <%# Tipo %>
              <div class="col-md-2">
                <%= f.label :tipo_eq, "Tipo", class: "form-label" %>
                <%= f.select :tipo_eq,
                    options_for_select([
                      ['Todos', ''],
                      ['Venta', '0'],
                      ['Abono', '1']
                    ], params.dig(:q, :tipo_eq)),
                    {}, class: "form-select" %>
              </div>
              
              <%# Serie del recibo %>
              <div class="col-md-2">
                <%= f.label :recibo_serie_eq, "Serie recibo", class: "form-label" %>
                <%= f.select :recibo_serie_eq,
                    options_for_select([
                      ['Todas', ''],
                      ['A (Hacienda)', 'A'],
                      ['B (Mano)', 'B']
                    ], params.dig(:q, :recibo_serie_eq)),
                    {}, class: "form-select" %>
              </div>
              
              <%# Estado de remesa %>
              <div class="col-md-2">
                <%= f.label :recibo_remesa_id_present, "Remesa", class: "form-label" %>
                <%= f.select :recibo_remesa_id_present,
                    options_for_select([
                      ['Todos', ''],
                      ['Remesado (banco)', 'true'],
                      ['No remesado (bizum)', 'false']
                    ], params.dig(:q, :recibo_remesa_id_present)),
                    {}, class: "form-select" %>
              </div>
              
              <%# Número de factura %>
              <div class="col-md-3">
                <%= f.label :numero_cont, "Nº Factura", class: "form-label" %>
                <%= f.search_field :numero_cont, 
                    class: "form-control", 
                    placeholder: "Ej: 20250001",
                    value: params.dig(:q, :numero_cont) %>
              </div>
              
              <div class="col-12 d-flex justify-content-end gap-2">
                <%= f.submit "Filtrar", class: "btn btn-primary" %>
                <%= link_to "Limpiar", facturacion_trimestre_path(@trimestre), class: "btn btn-outline-secondary" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>


   <%# Lista de facturas con FECHA %>
    <div class="row">
      <div class="col-12">
        <h5 class="mb-3"><i class="bi bi-list-check me-2"></i>Facturas del trimestre</h5>
        
        <div class="list-group">
          <% @facturas.each do |factura| %>
            <div class="list-group-item list-group-item-action mb-2 rounded border p-3">
              
              <%# Fila principal con fecha añadida %>
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                  <%# Icono tipo %>
                  <% if factura.venta? %>
                    <span class="badge bg-primary" title="Venta"><i class="bi bi-cart"></i></span>
                  <% else %>
                    <span class="badge bg-warning text-dark" title="Abono"><i class="bi bi-arrow-counterclockwise"></i></span>
                  <% end %>
                  
                  <%# Icono estado %>
                  <% if factura.borrador? %>
                    <span class="badge bg-secondary" title="Borrador"><i class="bi bi-pencil-square"></i></span>
                  <% elsif factura.emitida? %>
                    <span class="badge bg-success" title="Emitida"><i class="bi bi-check-circle-fill"></i></span>
                  <% end %>
                  
                  <div class="d-flex flex-column">
                    <code class="fs-6"><%= factura.numero %></code>
                    <small class="text-muted">
                      <i class="bi bi-calendar3 me-1"></i><%= l(factura.fecha_emision, format: :short) if factura.fecha_emision %>
                    </small>
                  </div>
                  
                  <% if factura.recibo&.usuario %>
                    <span class="fw-bold"><%= factura.recibo.usuario.nombre %></span>
                  <% else %>
                    <span class="text-muted">Sin alumno</span>
                  <% end %>
                </div>
                
                <div class="d-flex align-items-center gap-3">
                  <span class="fs-5 fw-bold text-primary"><%= number_to_currency(factura.total, unit: '€') %></span>
                  <button class="btn btn-outline-primary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#detalle-<%=factura.id%>">
                    <i class="bi bi-eye me-1"></i>rcb-<%= factura.recibo_id %>
                  </button>
                </div>
              </div>
   

            <%# Panel expandible con datos del recibo %>
            <div id="detalle-<%=factura.id%>" class="collapse mt-3">
              <% if factura.recibo %>
                <div class="card bg-light border-0">
                  <div class="card-body">
                    <div class="row">
                      <div class="col-md-6">
                        <h6 class="text-muted mb-3"><i class="bi bi-person me-2"></i>Datos del Alumno</h6>
                        <p class="mb-1"><strong>Nombre:</strong> <%= factura.recibo.usuario&.nombre || "N/A" %></p>
                        <p class="mb-1"><strong>DNI:</strong> <%= factura.recibo.usuario&.dni || "N/A" %></p>
                        <p class="mb-1"><strong>Email:</strong> <%= factura.recibo.usuario&.email || "N/A" %></p>
                      </div>
                      <div class="col-md-6">
                        <h6 class="text-muted mb-3"><i class="bi bi-bank me-2"></i>Datos Bancarios</h6>
                        <p class="mb-1"><strong>IBAN:</strong> <code><%= factura.recibo.iban %></code></p>
                        <p class="mb-1"><strong>BIC:</strong> <%= factura.recibo.bic %></p>
                        <p class="mb-1"><strong>Importe:</strong> <%= number_to_currency(factura.recibo.importe, unit: '€') %></p>
                      </div>
                    </div>

                    <div class="row mt-3">
                      <div class="col-md-6">
                        <p class="mb-1"><strong>Serie:</strong> <%= factura.recibo.serie %></p>
                        <p class="mb-1"><strong>Estado recibo:</strong>
                          <span class="badge bg-<%= factura.recibo.reciboEstado.color %>"><%= factura.recibo.reciboEstado.nombre %></span>
                        </p>
                        <% if factura.recibo.remesa_id %>
                          <p class="mb-1">
                            <strong>Remesa:</strong>
                            <%= link_to "Ver remesa ##{factura.recibo.remesa_id}", remesa_show_path(factura.recibo.remesa_id), class: "btn btn-sm btn-outline-info" %>
                          </p>
                        <% end %>
                      </div>
                      <div class="col-md-6">
                        <p class="mb-1"><strong>Vencimiento:</strong> <%= l(factura.recibo.vencimiento, format: :long) if factura.recibo.vencimiento %></p>
                        <p class="mb-1"><strong>Concepto:</strong> <%= factura.recibo.concepto %></p>
                      </div>
                    </div>

                    <div class="mt-3 text-end">
                      <%= link_to recibo_facturaPdf_path(factura.recibo, format: :pdf), class: 'btn btn-sm btn-danger', target: "_blank" do %>
                        <i class="bi bi-file-pdf me-1"></i>Ver PDF
                      <% end %>
                    </div>
                  </div>
                </div>
              <% else %>
                <div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Sin recibo asociado</div>
              <% end %>
            </div>

          </div>
        <% end %>
      </div>

      <%= paginate @facturas %>
    </div>
  </div>

  <div class="mt-4 mb-4">
    <%= link_to "← Volver a trimestres", facturacion_trimestres_path, class: "btn btn-secondary" %>
  </div>





  <div class="modal fade" id="modalVerificacion" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content" id="contenidoVerificacion"></div>
  </div>
</div>

<%# JavaScript - añade esto también al final %>
<script>
function abrirVerificacion(url) {
  console.log('Click en verificar, URL:', url);

  var modalEl = document.getElementById('modalVerificacion');
  var contenido = document.getElementById('contenidoVerificacion');

  // Mostrar spinner
  contenido.innerHTML = '<div class="modal-header"><h5>Cargando...</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body text-center p-4"><div class="spinner-border text-primary"></div></div>';

  // Abrir modal con Bootstrap 5
  var modal = new bootstrap.Modal(modalEl);
  modal.show();

  // Token CSRF
  var token = document.querySelector('meta[name="csrf-token"]');
  if (!token) {
    console.error('No hay token CSRF');
    contenido.innerHTML = '<div class="modal-body"><div class="alert alert-danger">Error: No hay token CSRF</div></div>';
    return;
  }

  // Petición AJAX
  fetch(url, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/x-www-form-urlencoded',
      'X-CSRF-Token': token.content
    },
    body: 'authenticity_token=' + encodeURIComponent(token.content)
  })
  .then(function(response) {
    console.log('Respuesta status:', response.status);
    if (!response.ok) throw new Error('HTTP ' + response.status);
    return response.text();
  })
  .then(function(html) {
    console.log('HTML recibido, longitud:', html.length);
    contenido.innerHTML = html;
  })
  .catch(function(error) {
    console.error('Error:', error);
    contenido.innerHTML = '<div class="modal-header bg-danger text-white"><h5>Error</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="alert alert-danger">' + error.message + '</div></div>';
  });
}
</script>
</div>
