<section class="container mt-4">
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
    
    <!-- TARJETA DE CLASES -->
    <div class="col">
      <div class="card h-100 border-primary">
        <div class="card-header bg-primary text-white">
          <h5><i class="bi bi-book me-2"></i>Clases</h5>
        </div>
        <div class="card-body">
          <div class="d-grid gap-3">
            <%= link_to clase_calendario_path(fecha: Date.today), class: 'btn btn-outline-primary text-start' do %>
              <i class="bi bi-calendar-week me-2"></i>Calendario Agendado
            <% end %>

            <div class="accordion" id="clasesAccordion">
              <!-- Ver Clases Día -->
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseClasesDia">
                    <i class="bi bi-calendar-day me-2"></i>Ver clases día
                  </button>
                </h2>
                <div id="collapseClasesDia" class="accordion-collapse collapse" data-bs-parent="#clasesAccordion">
                  <div class="accordion-body p-2">
                    <%= form_tag(clase_seleccion_dia_path, method: :post) do %>
                      <input name="fecha" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <button class="btn btn-sm btn-primary w-100" type="submit">Ver</button>
                    <% end %>
                  </div>
                </div>
              </div>

              <!-- Ver Semana -->
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseClasesSemana">
                    <i class="bi bi-calendar-range me-2"></i>Ver semana
                  </button>
                </h2>
                <div id="collapseClasesSemana" class="accordion-collapse collapse" data-bs-parent="#clasesAccordion">
                  <div class="accordion-body p-2">
                    <%= form_tag(clase_seleccion_path, method: :post) do %>
                      <input name="fecha" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <button class="btn btn-sm btn-primary w-100" type="submit">Ver</button>
                    <% end %>
                  </div>
                </div>
              </div>

              <!-- Horas Libres -->
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseHorasLibres">
                    <i class="bi bi-clock-history me-2"></i>Horas libres
                  </button>
                </h2>
                <div id="collapseHorasLibres" class="accordion-collapse collapse" data-bs-parent="#clasesAccordion">
                  <div class="accordion-body p-2">
                    <%= form_tag(clase_seleccion_dia_path, method: :post) do %>
                      <input name="fecha" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <button class="btn btn-sm btn-primary w-100" type="submit">Libre este día</button>
                    <% end %>
                    <%= form_tag(clase_seleccion_path, method: :post, class: 'mt-2') do %>
                      <input name="fecha" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <button class="btn btn-sm btn-primary w-100" type="submit">Libre esta semana</button>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- TARJETA DE ALUMNOS -->
    <div class="col">
      <div class="card h-100 border-success">
        <div class="card-header bg-success text-white">
          <h5><i class="bi bi-people-fill me-2"></i>Alumnos</h5>
        </div>
        <div class="card-body">
          <div class="d-grid gap-3">
            <%= link_to alumnos_path, class: 'btn btn-outline-success text-start' do %>
              <i class="bi bi-list-ul me-2"></i>Listado alumnos
            <% end %>

            <%= link_to nueva_alta_alumnos_path, class: 'btn btn-outline-success text-start' do %>
              <i class="bi bi-person-plus me-2"></i>Nuevo alumno
            <% end %>

            <%= link_to alumnos_pdfAlumnos_path, class: 'btn btn-outline-success text-start' do %>
              <i class="bi bi-file-earmark-excel me-2"></i>ODS alumnos
            <% end %>

            <div class="accordion" id="alumnosAccordion">
              <!-- Altas -->
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAltas">
                    <i class="bi bi-person-plus me-2"></i>Altas
                  </button>
                </h2>
                <div id="collapseAltas" class="accordion-collapse collapse" data-bs-parent="#alumnosAccordion">
                  <div class="accordion-body p-2">
                    <%= form_tag(alumnos_business_path, method: :post) do %>
                      <input name="fecha" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <button class="btn btn-sm btn-success w-100" type="submit">Altas en fecha</button>
                    <% end %>
                  </div>
                </div>
              </div>

              <!-- Clases Agendadas -->
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseClasesAlumnos">
                    <i class="bi bi-calendar-check me-2"></i>Clases Agendadas
                  </button>
                </h2>
                <div id="collapseClasesAlumnos" class="accordion-collapse collapse" data-bs-parent="#alumnosAccordion">
                  <div class="accordion-body p-2">
                    <%= form_tag(alumno_clases_agendadas_path(1), method: :get) do %>
                      <input name="fechaInicio" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <input name="fechaFin" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <button class="btn btn-sm btn-success w-100" type="submit">Buscar</button>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- TARJETA DE HORARIO -->
    <div class="col">
      <div class="card h-100 border-info">
        <div class="card-header bg-info text-white d-flex justify-content-between">
          <h5><i class="bi bi-calendar-event me-2"></i>Horario</h5>
          <span class="badge bg-light text-dark"><%= @alumnosTotal.count unless @alumnosTotal.blank? %></span>
        </div>
        <div class="card-body">
          <div class="d-grid gap-3">
            <%= link_to horario_nuevo_path, class: 'btn btn-outline-info text-start' do %>
              <i class="bi bi-file-earmark-text me-2"></i>Plantilla general
            <% end %>

            <%= link_to horario_libre_path, class: 'btn btn-outline-info text-start' do %>
              <i class="bi bi-clock me-2"></i>Horas libres
            <% end %>

            <%= link_to horario_crear_path, class: 'btn btn-outline-info text-start' do %>
              <i class="bi bi-plus-circle me-2"></i>Crear horario
            <% end %>

            <div class="accordion" id="horarioAccordion">
              <!-- Crear Julio -->
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseJulio">
                    <i class="bi bi-calendar-month me-2"></i>Crear Julio
                  </button>
                </h2>
                <div id="collapseJulio" class="accordion-collapse collapse" data-bs-parent="#horarioAccordion">
                  <div class="accordion-body p-2">
                    <%= form_tag('/horario/crear_horario_julio', method: :post) do %>
                      <label class="form-label small">Selecciona semana:</label>
                      <input name="fecha" class="form-control mb-2" type="date">
                      <button class="btn btn-sm btn-info w-100" type="submit">Generar</button>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>

            <%= link_to julio_generate_pdf_path(format: :pdf), class: 'btn btn-outline-info text-start mt-2' do %>
              <i class="bi bi-file-pdf me-2"></i>Asistencia Julio
            <% end %>
          </div>
        </div>
      </div>
    </div>
    
    <!-- TARJETA DE FACTURACIÓN - ACTUALIZADA -->
    <div class="col">
      <div class="card h-100 border-warning">
        <div class="card-header bg-warning text-dark">
          <h5><i class="bi bi-receipt me-2"></i>Facturación</h5>
        </div>
        <div class="card-body">
          <div class="d-grid gap-3">
            <%# NUEVO: Enlace principal a gestión trimestral %>
            <%= link_to facturacion_trimestres_path, class: 'btn btn-warning text-start fw-bold' do %>
              <i class="bi bi-calendar3 me-2"></i>Gestión Trimestral
              <span class="badge bg-danger ms-2">Nuevo</span>
            <% end %>
            <%if false %>
          <%= link_to facturacion_path, class: 'btn btn-outline-warning text-start' do %>
              <i class="bi bi-list-check me-2"></i>Listado facturación (legacy)
            <% end %>
<%end%>
            <div class="accordion" id="facturacionAccordion">
              <%# NUEVO: Exportar Trimestre %>
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseExportarTrimestre">
                    <i class="bi bi-file-earmark-excel me-2"></i> Exportar Trimestre (Nuevo)
                  </button>
                </h2>
                <div id="collapseExportarTrimestre" class="accordion-collapse collapse" data-bs-parent="#facturacionAccordion">
                  <div class="accordion-body p-2">
                    <div class="accordion-body p-2">
                      <label class="form-label small">Selecciona trimestre:</label>
                      <select id="select-trimestre" class="form-select form-select-sm mb-2">
                        <option value="2025T1">2025 T1 (Ene-Mar)</option>
                        <option value="2025T2">2025 T2 (Abr-Jun)</option>
                        <option value="2025T3">2025 T3 (Jul-Sep)</option>
                        <option value="2025T4">2025 T4 (Oct-Dic)</option>
                      </select>
                      <%= link_to "Ir a trimestre", "#", id: "link-ir-trimestre", class: "btn btn-sm btn-warning w-100" %>
                    </div>
                  </div>
                </div>
              </div>

              <%# DEPRECATED: Yacob XLS - Ocultar o mantener para histórico %>
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed text-muted" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFacturasODS">
                    <i class="bi bi-file-excel me-2"></i> Yacob XLS (deprecated)
                  </button>
                </h2>
                <div id="collapseFacturasODS" class="accordion-collapse collapse" data-bs-parent="#facturacionAccordion">
                  <div class="accordion-body p-2">
                    <div class="alert alert-warning small mb-2">
                      <i class="bi bi-exclamation-triangle me-1"></i>
                      Usar solo para histórico pre-2025
                    </div>
                    <%= form_tag(recibo_yacob_path, method: :post, data: { turbo: false }, target: "_blank") do %>
                      <input name="fechaInicio" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <input name="fechaFin" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <button class="btn btn-sm btn-outline-secondary w-100" type="submit">Generar (legacy)</button>
                    <% end %>
                  </div>
                </div>
              </div>

              <%# DEPRECATED: Exportar FacturaDirecta %>
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed text-muted" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFacturaDirecta">
                    <i class="bi bi-cloud-upload me-2"></i> Exportar FacturaDirecta (deprecated)
                  </button>
                </h2>
                <div id="collapseFacturaDirecta" class="accordion-collapse collapse" data-bs-parent="#facturacionAccordion">
                  <div class="accordion-body p-2">
                    <div class="alert alert-warning small mb-2">
                      <i class="bi bi-exclamation-triangle me-1"></i>
                      Funcionalidad legacy. Usar Gestión Trimestral.
                    </div>
                    <%= form_tag(recibo_exportar_facturadirecta_path, method: :post, data: { turbo: false }) do %>
                      <div class="mb-2">
                        <label class="form-label small">Fecha inicio:</label>
                        <input name="fechaInicio" class="form-control form-control-sm" type="date" value="<%= @fechaHoy %>" required>
                      </div>
                      <div class="mb-2">
                        <label class="form-label small">Fecha fin:</label>
                        <input name="fechaFin" class="form-control form-control-sm" type="date" value="<%= @fechaHoy %>" required>
                      </div>
                      <button class="btn btn-sm btn-outline-secondary w-100" type="submit">
                        <i class="fas fa-file-export"></i> Exportar (legacy)
                      </button>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- TARJETA DE REMESAS -->
    <div class="col">
      <div class="card h-100 border-danger">
        <div class="card-header bg-danger text-white">
          <h5><i class="bi bi-cash-stack me-2"></i>Recibos y Remesas</h5>
        </div>
        <div class="card-body">
          <div class="d-grid gap-3">
            <%= link_to remesa_index_path, class: 'btn btn-outline-danger text-start' do %>
              <i class="ei bi-list-ul me-2"></i>Listado Remesas
            <% end %>

            <%= link_to gestion_recibos_path, class: 'btn btn-outline-danger text-start' do %>
              <i class="bi bi-check2-square me-2"></i>Gestion de Recibos
            <% end %>

            <!-- Pagos de Recibos -->
            <%= link_to recibo_pagos_path, class: 'btn btn-outline-danger text-start' do %>
              <i class="bi bi-list-ul me-2"></i>Pago Recibos
            <% end %>

            <div class="accordion" id="remesasAccordion">
              <!-- Generar Recibos -->
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseGenerarRecibos">
                    <i class="bi bi-file-earmark-plus me-2"></i>Generar Recibos
                  </button>
                </h2>
                <div id="collapseGenerarRecibos" class="accordion-collapse collapse" data-bs-parent="#remesasAccordion">
                  <div class="accordion-body p-2">
                    <%= form_tag(recibo_generarPost_path, method: :post) do %>
                      <input name="fecha" class="form-control mb-2" type="date" value="<%= Date.current %>">
                      <button class="btn btn-sm btn-danger w-100" type="submit">Generar</button>
                    <% end %>
                  </div>
                </div>
              </div>

              <!-- Numerar -->
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseNumerar">
                    <i class="bi bi-123 me-2"></i>Numerar
                  </button>
                </h2>
                <div id="collapseNumerar" class="accordion-collapse collapse" data-bs-parent="#remesasAccordion">
                  <div class="accordion-body p-2">
                    <%= form_tag(recibo_numerarPost_path, method: :post) do %>
                      <input name="fechaInicio" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <input name="fechaFin" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <button class="btn btn-sm btn-danger w-100" type="submit">Numerar</button>
                    <% end %>
                  </div>
                </div>
              </div>

              <!-- Remesar -->
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseRemesar">
                    <i class="bi bi-send me-2"></i>Remesar
                  </button>
                </h2>
                <div id="collapseRemesar" class="accordion-collapse collapse" data-bs-parent="#remesasAccordion">
                  <div class="accordion-body p-2">
                    <%= form_tag(recibo_remesar_path, method: :post) do %>
                      <input name="fechaInicio" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <input name="fechaFin" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <button class="btn btn-sm btn-danger w-100" type="submit">Remesar</button>
                    <% end %>
                  </div>
                </div>
              </div>

              <!-- Descargar ODS -->
              <div class="accordion-item">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseDescargarODS">
                    <i class="bi bi-download me-2"></i>Descargar ODS
                  </button>
                </h2>
                <div id="collapseDescargarODS" class="accordion-collapse collapse" data-bs-parent="#remesasAccordion">
                  <div class="accordion-body p-2">
                    <%= form_tag(recibo_descargarFacturacion_path, method: :post) do %>
                      <input name="fechaInicio" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <input name="fechaFin" class="form-control mb-2" type="date" value="<%= @fechaHoy %>">
                      <button class="btn btn-sm btn-danger w-100" type="submit">Descargar</button>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>

            <%= link_to caja_listado_path, class: 'btn btn-outline-danger text-start mt-2' do %>
              <i class="bi bi-cash-coin me-2"></i>Apuntes en caja
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- TARJETA DE ESTADÍSTICAS EXPANDIDA - Versión SCSS -->
<div class="col">
  <div class="card h-100 card-border-purple">
    <div class="card-header bg-purple text-white d-flex justify-content-between align-items-center">
      <h5 class="mb-0">
        <i class="bi bi-graph-up me-2"></i>Estadísticas
      </h5>
      <span class="badge badge-purple"><%= @key_metrics[:active_students] if @key_metrics %></span>
    </div>
    <div class="card-body">
      <div class="d-grid gap-2">
        <!-- Enlaces existentes -->
        <%= link_to stats_monthly_comparison_path, class: 'btn btn-outline-purple text-start' do %>
          <i class="bi bi-calendar-month me-2"></i>Comparación Mensual
        <% end %>

        <%= link_to stats_evolucion_ingresos_path, class: 'btn btn-outline-purple text-start' do %>
          <i class="bi bi-currency-euro me-2"></i>Evolución de Ingresos
        <% end %>

        <!-- Nuevos enlaces para gráficos de asistencia -->
        <%= link_to stats_dashboard_path, class: 'btn btn-outline-purple text-start' do %>
          <i class="bi bi-speedometer2 me-2"></i>Dashboard General
        <% end %>

        <div class="accordion mt-2" id="estadisticasAccordion">
          <!-- Asistencia Mensual -->
          <div class="accordion-item">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAsistencia">
                <i class="bi bi-calendar-heart me-2"></i>Asistencia Mensual
              </button>
            </h2>
            <div id="collapseAsistencia" class="accordion-collapse collapse" data-bs-parent="#estadisticasAccordion">
              <div class="accordion-body p-2">
                <%= form_tag(stats_asistencia_mensual_path, method: :get, class: 'small-form') do %>
                  <div class="mb-2">
                    <label class="form-label small">Mes:</label>
                    <input name="mes" class="form-control form-control-sm" type="month" value="<%= Date.today.strftime('%Y-%m') %>">
                  </div>
                  <button class="btn btn-purple btn-sm w-100" type="submit">Ver Gráfico</button>
                <% end %>
              </div>
            </div>
          </div>

          <!-- Por Instructor -->
          <div class="accordion-item">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseInstructor">
                <i class="bi bi-person-badge me-2"></i>Por Instructor
              </button>
            </h2>
            <div id="collapseInstructor" class="accordion-collapse collapse" data-bs-parent="#estadisticasAccordion">
              <div class="accordion-body p-2">
                <%= form_tag(stats_asistencia_instructor_path, method: :get, class: 'small-form') do %>
                  <div class="mb-2">
                    <label class="form-label small">Instructor:</label>
                    <select name="instructor_id" class="form-select form-select-sm">
                      <%= options_from_collection_for_select(Instructor.all, :id, :nombre) %>
                    </select>
                  </div>
                  <div class="mb-2">
                    <label class="form-label small">Mes:</label>
                    <input name="mes" class="form-control form-control-sm" type="month" value="<%= Date.today.strftime('%Y-%m') %>">
                  </div>
                  <button class="btn btn-purple btn-sm w-100" type="submit">Ver Gráfico</button>
                <% end %>
              </div>
            </div>
          </div>

          <!-- Métricas Rápidas -->
          <div class="accordion-item">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseMetricas">
                <i class="bi bi-speedometer me-2"></i>Métricas Rápidas
              </button>
            </h2>
            <div id="collapseMetricas" class="accordion-collapse collapse" data-bs-parent="#estadisticasAccordion">
              <div class="accordion-body p-2">
                <!-- Mini dashboard de métricas -->
                <% if @key_metrics %>
                  <div class="metricas-rapidas">
                    <div class="metric-item">
                      <div class="d-flex justify-content-between">
                        <span class="small">Alumnos Activos:</span>
                        <strong class="metric-value"><%= @key_metrics[:active_students] %></strong>
                      </div>
                    </div>
                    <div class="metric-item">
                      <div class="d-flex justify-content-between">
                        <span class="small">Asistencia Mes:</span>
                        <strong class="metric-value"><%= @key_metrics[:monthly_attendance_rate] %>%</strong>
                      </div>
                    </div>
                    <div class="metric-item">
                      <div class="d-flex justify-content-between">
                        <span class="small">Retención:</span>
                        <strong class="metric-value"><%= @key_metrics[:retention_rate] %>%</strong>
                      </div>
                    </div>
                    <div class="metric-item">
                      <div class="d-flex justify-content-between">
                        <span class="small">Clases/Alumno:</span>
                        <strong class="metric-value"><%= @key_metrics[:avg_classes_per_student] %></strong>
                      </div>
                    </div>
                  </div>
                <% else %>
                  <p class="text-muted small">Cargando métricas...</p>
                <% end %>
                <%= link_to 'Actualizar Métricas', stats_dashboard_path, class: 'btn btn-outline-purple btn-sm w-100 mt-2' %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

  </div>

</section>

<%= content_for :js do %>
  <script>
        // Activar tooltips
    document.addEventListener('DOMContentLoaded', function() {
      var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
      var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl)
      });

      <%# NUEVO: Link dinámico a trimestre %>
      var selectTrimestre = document.getElementById('select-trimestre');
      var linkIrTrimestre = document.getElementById('link-ir-trimestre');

      if (selectTrimestre && linkIrTrimestre) {
        function actualizarLink() {
          var trimestre = selectTrimestre.value;
          linkIrTrimestre.href = '/facturacion/' + trimestre;
        }

        selectTrimestre.addEventListener('change', actualizarLink);
        actualizarLink();
      }
    });
  </script>
<% end %>
