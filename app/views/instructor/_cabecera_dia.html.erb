<div class="sticky-top bg-white p-2 border-bottom">
  <div class="d-flex justify-content-between align-items-center">
    <%= link_to instructor_dianuevo_path(fecha: @fecha - 1.day),
                class: "btn btn-sm btn-outline-primary" do %>
      <i class="bi bi-chevron-left"></i>
    <% end %>

    <h5 class="text-center mb-0">
      <%= l(@fecha, format: "%A %d/%m").upcase %>
    </h5>

    <%= link_to instructor_dianuevo_path(fecha: @fecha + 1.day),
                class: "btn btn-sm btn-outline-primary" do %>
      <i class="bi bi-chevron-right"></i>
    <% end %>
  </div>

  <%= form_with url: instructor_dianuevo_path, method: :get,
                class: "mt-2 row g-1" do |f| %>
    <div class="col-8">
      <%= f.date_field :fecha, value: @fecha,
                      class: "form-control form-control-sm" %>
    </div>
    <div class="col-4">
      <%= f.submit "IR", class: "btn btn-primary btn-sm w-100" %>
    </div>
  <% end %>
</div>
