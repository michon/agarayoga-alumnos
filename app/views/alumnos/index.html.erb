<% content_for :title, "Listado de Alumnos" %>

<div class="container">
  <!-- Barra de búsqueda -->
  <div class="card mb-4 shadow-sm">
    <div class="card-body">
      <%= search_form_for(@q, url: alumnos_index_path, method: :get) do |f| %>
        <div class="input-group">
          <%= f.search_field :nombre_cont, class: "form-control", placeholder: "Buscar alumno..." %>
          <%= f.submit 'Buscar', class: "btn btn-primary" %>
          <%= link_to 'Limpiar', alumnos_index_path, class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Lista de alumnos -->
  <% @alumnos.each do |alumno| %>
    <div class="card mb-3 shadow-sm">
      <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
          <%= alumno.nombre %>
          <% if alumno.alias.present? %>
            <small class="text-muted">(<%= alumno.alias %>)</small>
          <% end %>
        </h5>
        <span class="badge bg-<%= alumno.regalo ? 'success' : 'warning' %>">
          <%= alumno.regalo ? 'Regalo enviado' : 'Pendiente' %>
        </span>
      </div>

      <div class="card-body">
        <!-- Botones principales -->
        <div class="d-flex flex-wrap gap-2 mb-3">
          <%= link_to "📄 Ficha PDF", alumnos_path(alumno, format: :pdf), class: "btn btn-sm btn-outline-primary" %>
          <%= link_to "📅 Clases Agendadas", "#clases-#{alumno.id}", class: "btn btn-sm btn-outline-info", data: { bs_toggle: "collapse" } %>
          <%= link_to "📤 WhatsApp", "#whatsapp-#{alumno.id}", class: "btn btn-sm btn-outline-success", data: { bs_toggle: "collapse" } %>
          <%= link_to "🕒 Historial", "#historial-#{alumno.id}", class: "btn btn-sm btn-outline-secondary", data: { bs_toggle: "collapse" } %>
          <%= link_to "👁‍🗨 Ver", alumnos_path(alumno), class: "btn btn-sm btn-outline-dark" %>
        </div>

        <!-- Panel de CLASES AGENDADAS (colapsable) -->
        <div class="collapse mb-3" id="clases-<%= alumno.id %>">
          <div class="card card-body">
            <h6><i class="bi bi-calendar3"></i> Clases Programadas</h6>
            <% if @clases.where(usuario_id: alumno.id).any? %>
              <ul class="list-group list-group-flush">
                <% @clases.where(usuario_id: alumno.id).order(:diaHora).each do |clase| %>
                  <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                      <% if clase.clase.present? %>
                        <%= link_to clase.clase.clase_humano, clase_dia_path(clase.diaHora.strftime('%F')), class: "text-decoration-none" %>
                      <% else %>
                        <span class="text-danger">Clase no disponible</span>
                      <% end %>1
                      <small class="text-muted d-block">
                        <%= I18n.l(clase.diaHora, format: "%A %d/%m a las %H:%M") %>
                      </small>
                    </div>
                    <span class="badge bg-<%= clase.claseAlumnoEstado.color %>">
                      <%= clase.claseAlumnoEstado.nombre %>
                    </span>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-muted">No hay clases agendadas.</p>
            <% end %>
          </div>
        </div>

        <!-- Panel de WHATSAPP (colapsable) -->
        <div class="collapse mb-3" id="whatsapp-<%= alumno.id %>">
          <div class="card card-body">
            <h6><i class="bi bi-whatsapp"></i> Mensaje para WhatsApp</h6>
            <div class="bg-light p-3 rounded mb-2" id="whatsapp-text-<%= alumno.id %>">
              <p>
                Hola <%= alumno.alias.presence || alumno.nombre.split.first %> 😊,<br>
                las clases que tenemos programadas son:<br><br>
                <% if @clases.where(usuario_id: alumno.id, claseAlumnoEstado_id: 1).any? %>
                  <% @clases.where(usuario_id: alumno.id, claseAlumnoEstado_id: 1).order(:diaHora).each do |cl| %>
                    -📅  <%= I18n.l(cl.diaHora, format: "%A %d/%m a las ⏰  %H:%M") %>
                    <% if cl.clase.present? && cl.clase.instructor.present? %>
                      con <%= cl.clase.instructor.nombre.split.first %><br>
                    <% end %>
                  <% end %>
                <% else %>
                  No tienes clases agendadas por ahora.
                <% end %>
              </p>
            </div>
            <button class="btn btn-sm btn-success" onclick="copyToClipboard('whatsapp-text-<%= alumno.id %>')">
              <i class="bi bi-clipboard"></i> Copiar texto
            </button>
            <% if alumno.movil.present? %>
              <%
                telefono = "34#{alumno.movil.to_s.gsub(/\D/, '')}"
                texto_whatsapp = @whatsapp_texts[alumno.id]

                # Codificación que preserva emojis (versión simplificada)
                texto_codificado = URI.encode_www_form_component(texto_whatsapp)
                                      .gsub(/\+/, '%20')
              %>

              <!-- Enlace directo para WhatsApp -->
              <a href="https://wa.me/<%= telefono %>?text=<%= texto_codificado %>"
                 class="btn btn-sm btn-success mt-2"
                 target="_blank"
                 onclick="window.open('whatsapp://send?phone=<%= telefono %>&text=<%= texto_codificado %>', '_blank'); return false;">
                <i class="bi bi-whatsapp"></i> Enviar por WhatsApp
              </a>
            <% end %>
          </div>
        </div>

        <!-- Panel de HISTORIAL (colapsable) -->
        <div class="collapse" id="historial-<%= alumno.id %>">
          <div class="card card-body">
            <h6><i class="bi bi-clock-history"></i> Historial de Clases</h6>
            <%= form_tag(alumno_clasesAgendadas_path, method: :post, class: "row g-3") do %>
              <%= hidden_field_tag :id, alumno.id %>
              <div class="col-md-5">
                <%= label_tag :fechaInicio, "Desde", class: "form-label" %>
                <%= date_field_tag :fechaInicio, @fechaInicio, class: "form-control" %>
              </div>
              <div class="col-md-5">
                <%= label_tag :fechaFin, "Hasta", class: "form-label" %>
                <%= date_field_tag :fechaFin, @fechaHoy, class: "form-control" %>
              </div>
              <div class="col-md-2 d-flex align-items-end">
                <%= submit_tag "Buscar", class: "btn btn-primary w-100" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
  function copyToClipboard(elementId) {
    const element = document.getElementById(elementId);
    const text = element.innerText;
    navigator.clipboard.writeText(text).then(() => {
      alert("Texto copiado al portapapeles ✅");
    });
  }
</script>
 <script>
    // Fuerza apertura en app nativa con fallback
    document.querySelectorAll('.whatsapp-btn').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        window.location.href = `whatsapp://send?phone=${this.dataset.phone}&text=${this.dataset.text}`;
        setTimeout(() => {
          window.open(`https://web.whatsapp.com/send?phone=${this.dataset.phone}&text=${this.dataset.text}`, '_blank');
        }, 500);
      });
    });
  </script>

