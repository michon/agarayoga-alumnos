<script>
  // Control de regalo con AJAX usando event delegation
document.addEventListener('DOMContentLoaded', function() {
  // Usar event delegation para manejar elementos dinámicos
  document.addEventListener('change', function(event) {
    if (event.target.classList.contains('regalo-switch')) {
      const switchElement = event.target;
      const alumnoId = switchElement.dataset.alumnoId;
      const isChecked = switchElement.checked;

      // Mostrar loading
      const label = document.getElementById(`label_regalo_${alumnoId}`);
      const badge = document.getElementById(`badge_regalo_${alumnoId}`);
      const originalLabelText = label.innerHTML;

      label.innerHTML = '⏳ Actualizando...';
      switchElement.disabled = true;

      // Hacer la petición a la ruta existente
      fetch(`/alumnos/regalo/${alumnoId}`, {
        method: 'GET',
        headers: {
          'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content,
          'Accept': 'application/json'
        }
      })
      .then(response => {
        if (!response.ok) {
          throw new Error('Error en la respuesta del servidor');
        }
        return response.json();
      })
      .then(data => {
        if (data.success) {
          // Actualizar la UI según la respuesta
          if (data.regalo) {
            label.innerHTML = '✅ Enviado';
            label.classList.remove('text-warning');
            label.classList.add('text-success');
            if (badge) {
              badge.innerHTML = 'Regalado';
              badge.className = 'badge bg-success';
            }
            switchElement.checked = true;
          } else {
            label.innerHTML = '🎁 Pendiente';
            label.classList.remove('text-success');
            label.classList.add('text-warning');
            if (badge) {
              badge.innerHTML = 'Pendiente';
              badge.className = 'badge bg-warning';
            }
            switchElement.checked = false;
          }
          showNotification(data.message, 'success');
        } else {
          throw new Error(data.message || 'Error desconocido');
        }
      })
      .catch(error => {
        console.error('Error:', error);
        // Revertir visualmente
        switchElement.checked = !isChecked;
        label.innerHTML = originalLabelText;
        showNotification('Error al actualizar el regalo: ' + error.message, 'error');
      })
      .finally(() => {
        switchElement.disabled = false;
      });
    }
  });

  function showNotification(message, type) {
    // Eliminar notificaciones existentes
    document.querySelectorAll('.alert-notification').forEach(alert => alert.remove());

    // Crear notificación temporal
    const notification = document.createElement('div');
    notification.className = `alert alert-${type === 'success' ? 'success' : 'danger'} position-fixed alert-notification`;
    notification.style.cssText = 'top: 20px; right: 20px; z-index: 1050; min-width: 300px;';
    notification.textContent = message;

    document.body.appendChild(notification);

    // Remover después de 3 segundos
    setTimeout(() => {
      notification.remove();
    }, 3000);
  }
});
</script>
