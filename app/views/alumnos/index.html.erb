<% content_for :title, "Listado de Alumnos" %>

<div class="container">
  <!-- Barra de búsqueda MEJORADA con filtros -->
  <div class="card mb-4 shadow-sm">
    <div class="card-header">
      <h5 class="mb-0">Filtros de Alumnos</h5>
    </div>
    <div class="card-body">
      <%= search_form_for(@q, url: alumnos_path, method: :get, class: "mb-0") do |f| %>
        <div class="row g-3">
          <!-- Campo de búsqueda por nombre -->
          <div class="col-md-5">
            <%= f.label :nombre_cont, "Buscar alumno", class: "form-label" %>
            <%= f.search_field :nombre_cont, class: "form-control", placeholder: "Nombre del alumno..." %>
          </div>
          
          <!-- Filtro por estado activo/inactivo -->
          <div class="col-md-4">
            <%= f.label :debaja_eq, "Estado", class: "form-label" %>
            <%= f.select :debaja_eq, 
                [
                  ['Todos', ''],
                  ['Activos', 'false'],
                  ['Inactivos', 'true']
                ], 
                { selected: params.dig(:q, :debaja_eq) },
                class: "form-select" %>
          </div>
          
          <!-- Botones de acción -->
          <div class="col-md-3 d-flex align-items-end">
            <div class="d-grid gap-2 w-100">
              <%= f.submit 'Buscar', class: "btn btn-primary" %>
              <%= link_to 'Limpiar', alumnos_path, class: "btn btn-outline-secondary" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Botones rápidos de filtro -->
  <div class="mb-4">
    <div class="btn-group" role="group" aria-label="Filtros rápidos">
      <%= link_to alumnos_path(q: { debaja_eq: 'false' }), 
          class: "btn btn-outline-primary #{'active' if params.dig(:q, :debaja_eq) == 'false'}" do %>
        <i class="bi bi-person-check"></i> Activos
        <span class="badge bg-primary"><%= Usuario.activo.count %></span>
      <% end %>
      
      <%= link_to alumnos_path(q: { debaja_eq: 'true' }), 
          class: "btn btn-outline-secondary #{'active' if params.dig(:q, :debaja_eq) == 'true'}" do %>
        <i class="bi bi-person-x"></i> Inactivos
        <span class="badge bg-secondary"><%= Usuario.inactivos.count %></span>
      <% end %>
      
      <%= link_to alumnos_path, 
          class: "btn btn-outline-info #{'active' unless params.dig(:q, :debaja_eq)}" do %>
        <i class="bi bi-people"></i> Todos
        <span class="badge bg-info"><%= Usuario.alumno.count %></span>
      <% end %>
    </div>
  </div>

  <!-- Mostrar información del filtro actual -->
  <% if params[:q] && params[:q][:debaja_eq].present? %>
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-4">
      <div>
        <i class="bi bi-funnel"></i>
        <strong>Filtro aplicado:</strong>
        <span class="badge bg-<%= params.dig(:q, :debaja_eq) == 'false' ? 'success' : 'secondary' %> ms-2">
          <%= params.dig(:q, :debaja_eq) == 'false' ? 'Solo activos' : 'Solo inactivos' %>
        </span>
        <span class="ms-2"><%= @alumnos.total_count %> alumnos encontrados (página <%= @alumnos.current_page %> de <%= @alumnos.total_pages %>)</span>
      </div>
      <%= link_to 'Limpiar filtro', alumnos_path, class: "btn btn-sm btn-outline-info" %>
    </div>
  <% elsif params[:q] && params[:q][:nombre_cont].present? %>
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-4">
      <div>
        <i class="bi bi-search"></i>
        <strong>Búsqueda:</strong>
        <span class="badge bg-primary ms-2">Nombre: <%= params.dig(:q, :nombre_cont) %></span>
        <span class="ms-2"><%= @alumnos.total_count %> alumnos (página <%= @alumnos.current_page %> de <%= @alumnos.total_pages %>)</span>
      </div>
      <%= link_to 'Limpiar búsqueda', alumnos_path, class: "btn btn-sm btn-outline-info" %>
    </div>
  <% end %>
  <!-- Lista de alumnos -->
  <% @alumnos.each do |alumno| %>
    <div class="card mb-3 shadow-sm">
      <div class="card-header bg-light d-flex justify-content-between align-items-center">
  <h5 class="mb-0">
    <%= alumno.nombre %>
    <% if alumno.alias.present? %>
      <small class="text-muted">(<%= alumno.alias %>)</small>
    <% end %>
  </h5>

  <div class="d-flex align-items-center gap-2">
    <!-- Switch con AJAX -->
    <div class="form-check form-switch">
      <input type="checkbox"
             class="form-check-input regalo-switch"
             id="regalo_<%= alumno.id %>"
             <%= 'checked' if alumno.regalo %>
             data-alumno-id="<%= alumno.id %>">
      <label class="form-check-label small fw-bold <%= alumno.regalo ? 'text-success' : 'text-warning' %>"
             for="regalo_<%= alumno.id %>" id="label_regalo_<%= alumno.id %>">
        <%= alumno.regalo ? '✅ Enviado' : '🎁 Pendiente' %>
      </label>
    </div>

    <!-- Badge que se actualizará con AJAX -->
    <span class="badge bg-<%= alumno.regalo ? 'success' : 'warning' %>" id="badge_regalo_<%= alumno.id %>">
      <%= alumno.regalo ? 'Regalado' : 'Pendiente' %>
    </span>
  </div>
</div>

      <div class="card-body">
        <!-- Botones principales -->
        <div class="d-flex flex-wrap gap-2 mb-3">
          <%= link_to "📅 Clases Agendadas", "#clases-#{alumno.id}", class: "btn btn-sm btn-outline-info", data: { bs_toggle: "collapse" } %>
          <%= link_to "📋 Horario", "#horario-#{alumno.id}", class: "btn btn-sm btn-outline-warning", data: { bs_toggle: "collapse" } %>
          <%= link_to "🗓️ Gestionar Horario", wizard_horario_paso1_path(alumno_id: alumno.id), class: "btn btn-sm btn-primary" %>
          <%= link_to "📤 WhatsApp", "#whatsapp-#{alumno.id}", class: "btn btn-sm btn-outline-success", data: { bs_toggle: "collapse" } %>
          <%= link_to "🔑 Generar Clave", "#", class: "btn btn-sm btn-outline-info generar-clave-btn", data: { alumno_id: alumno.id } %>
          <%= link_to "🕒 Historial", "#historial-#{alumno.id}", class: "btn btn-sm btn-outline-secondary", data: { bs_toggle: "collapse" } %>
          <%= link_to "💰 Recibos", "#recibos-#{alumno.id}", class: "btn btn-sm btn-outline-danger", data: { bs_toggle: "collapse" } %>
          <%= link_to "👁‍🗨 Ver", alumno_path(alumno.id), class: "btn btn-sm btn-outline-dark" %>
          <%= link_to "📄 Ficha PDF", alumno_path(alumno, format: :pdf), class: "btn btn-sm btn-outline-primary" %>
          <%= link_to "✏️ Editar", editar_alumno_path(alumno), class: "btn btn-sm btn-warning" %>
        </div>

        <!-- Panel de CLASES AGENDADAS (colapsable) -->
        <div class="collapse mb-3" id="clases-<%= alumno.id %>">
          <div class="card card-body">
            <h6><i class="bi bi-calendar3"></i> Clases Programadas</h6>
            <% clases_alumno = @clases_futuras[alumno.id] || [] %>
              <% if clases_alumno.any? %>
                <ul class="list-group list-group-flush">
                  <% clases_alumno.sort_by(&:diaHora).each do |clase| %>
                  <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                      <% if clase.clase.present? %>
                        <%= link_to clase.clase.clase_humano, clase_dia_path(clase.diaHora.strftime('%F'), 
                                                  anchor: "cuerpoTarjeta-#{clase.clase.id}",
                                                  highlight_alumno: clase.id), 
                                    class: "text-decoration-none text-#{clase.claseAlumnoEstado.color}", 
                                    target: "_blank" %>
                      <% else %>
                        <span class="text-danger">Clase no disponible</span>
                      <% end %>
                      <small class="text-muted d-block">
                        <%= I18n.l(clase.diaHora, format: "%A %d/%m a las %H:%M") %>
                      </small>
                    </div>
                    <span class="badge bg-<%= clase.claseAlumnoEstado.color %>">
                      <%= clase.claseAlumnoEstado.nombre %>
                    </span>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-muted">No hay clases agendadas.</p>
            <% end %>
          </div>
        </div>

        <!-- Panel de WHATSAPP (colapsable) -->
        <div class="collapse mb-3" id="whatsapp-<%= alumno.id %>">
          <div class="card card-body">
            <h6><i class="bi bi-whatsapp"></i> Mensaje para WhatsApp</h6>
            <div class="bg-light p-3 rounded mb-2" id="whatsapp-text-<%= alumno.id %>">
              <p>
                Hola <%= alumno.alias.presence || alumno.nombre.split.first %> 😊,<br>
                las clases que tenemos programadas son:<br><br>
                <% clases_activas_alumno = (@clases_futuras[alumno.id] || []).select { |c| c.claseAlumnoEstado_id == 1 } %>
                  <% if clases_activas_alumno.any? %>
                    <% clases_activas_alumno.sort_by(&:diaHora).each do |cl| %>
                    -📅  <%= I18n.l(cl.diaHora, format: "%A %d/%m a las ⏰  %H:%M") %>
                    <% if cl.clase.present? && cl.clase.instructor.present? %>
                      con <%= cl.clase.instructor.nombre.split.first %><br>
                    <% end %>
                  <% end %>
                <% else %>
                  No tienes clases agendadas por ahora.
                <% end %>
              </p>
            </div>
            <button class="btn btn-sm btn-success" onclick="copyToClipboard('whatsapp-text-<%= alumno.id %>')">
              <i class="bi bi-clipboard"></i> Copiar texto
            </button>
            <% if alumno.movil.present? %>
              <%
                telefono = "34#{alumno.movil.to_s.gsub(/\D/, '')}"
                texto_whatsapp = @whatsapp_texts[alumno.id]

                # Codificación que preserva emojis (versión simplificada)
                texto_codificado = URI.encode_www_form_component(texto_whatsapp)
                                      .gsub(/\+/, '%20')
              %>

              <!-- Enlace directo para WhatsApp -->
              <a href="https://wa.me/<%= telefono %>?text=<%= texto_codificado %>"
                 class="btn btn-sm btn-success mt-2"
                 target="_blank"
                 onclick="window.open('whatsapp://send?phone=<%= telefono %>&text=<%= texto_codificado %>', '_blank'); return false;">
                <i class="bi bi-whatsapp"></i> Enviar por WhatsApp
              </a>
            <% end %>
          </div>
        </div>

        <!-- Panel de HORARIO (colapsable) -->
        <div class="collapse mb-3" id="horario-<%= alumno.id %>">
          <div class="card card-body">
            <h6><i class="bi bi-calendar-week"></i> Horario del Alumno</h6>
            <% horarios = @horarios_por_alumno[alumno.id] %>
            <% if horarios&.any? %>
              <div class="table-responsive">
                <table class="table table-sm table-hover">
                  <thead class="table-light">
                    <tr>
                      <th>Día</th>
                      <th>Hora</th>
                      <th>Aula</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% # Agrupar horarios por día de la semana %>
                    <% dias_semana = {
                      1 => "Lunes",
                      2 => "Martes",
                      3 => "Miércoles",
                      4 => "Jueves",
                      5 => "Viernes",
                      6 => "Sábado",
                      7 => "Domingo"
                    } %>
                    
                    <% horarios.group_by { |h| h[:dia_semana] }.each do |dia, horarios_dia| %>
                      <% horarios_dia.sort_by { |h| [h[:hora], h[:minuto]] }.each_with_index do |horario, index| %>
                        <tr>
                          <% if index == 0 %>
                            <td rowspan="<%= horarios_dia.size %>" class="align-middle">
                              <strong><%= dias_semana[dia] || "Día #{dia}" %></strong>
                            </td>
                          <% end %>
                          <td><%= sprintf('%02d:%02d', horario[:hora], horario[:minuto]) %></td>
                          <td><%= horario[:aula]&.nombre || 'Sin aula asignada' %></td>
                        </tr>
                      <% end %>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% else %>
              <p class="text-muted">El alumno no tiene horarios asignados.</p>
            <% end %>
          </div>
        </div>

<!-- Panel de RECIBOS (colapsable) -->
<div class="collapse mb-3" id="recibos-<%= alumno.id %>">
  <div class="card card-body">
    <h6><i class="bi bi-receipt"></i> Últimos 12 Recibos Emitidos</h6>
    <% recibos = @recibos_por_alumno[alumno.id] %>
    <% if recibos&.any? %>
      <p class="text-muted small">Mostrando los 12 recibos más recientes</p>
      <div class="table-responsive">
        <table class="table table-sm table-hover">
          <thead class="table-light">
            <tr>
              <th>Vencimiento</th>
              <th>Concepto</th>
              <th>Importe</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% recibos.each do |recibo| %>
              <tr>
                <td><%= recibo.vencimiento.strftime("%d/%m/%Y") if recibo.vencimiento %></td>
                <td><%= recibo.concepto %></td>
                <td><%= number_to_currency(recibo.importe, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %></td>
                <td>
                  <span class="badge bg-<%= recibo.reciboEstado.color %>">
                    <%= recibo.reciboEstado.nombre %>
                  </span>
                </td>
                <td>
                  <%= link_to "👁‍🗨", edit_gestion_recibo_path(recibo), class: "btn btn-sm btn-outline-info" if defined?(recibo_path) %>
                  <%= link_to "📄", recibo_path(recibo, format: :pdf), class: "btn btn-sm btn-outline-primary" if defined?(recibo_path) %>
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr class="table-active">
              <td colspan="2"><strong>Total</strong></td>
              <td><strong><%= number_to_currency(recibos.sum { |r| r.importe.to_f }, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %></strong></td>
              <td colspan="2">
                <span class="badge bg-info">
                    <%= recibos.count { |r| !r.reciboEstado_id.nil? && r.reciboEstado_id == 2 } %>/<%= recibos.count %> pagados
                </span>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
      
      <!-- Enlace para ver todos los recibos si hay más de 12 -->
     <% total_recibos = alumno.recibos.size %>
      <% if total_recibos > 12 %>
        <div class="mt-2">
          <%= link_to "📋 Ver todos los recibos (#{total_recibos} total)", recibos_path(q: { usuario_id_eq: alumno.id }), class: "btn btn-sm btn-outline-secondary" if defined?(recibos_path) %>
        </div>
      <% end %>
      
    <% else %>
      <p class="text-muted">No se han emitido recibos para este alumno.</p>
    <% end %>
    
    <% if defined?(new_recibo_path) %>
      <div class="mt-3">
        <%= link_to "➕ Emitir nuevo recibo", new_recibo_path(usuario_id: alumno.id), class: "btn btn-sm btn-success" %>
      </div>
    <% end %>
  </div>
</div>




        <!-- Panel de HISTORIAL (colapsable) -->
        <div class="collapse" id="historial-<%= alumno.id %>">
          <div class="card card-body">
            <h6><i class="bi bi-clock-history"></i> Historial de Clases</h6>
            <%= form_tag(alumno_clases_agendadas_path(alumno.id), method: :get, class: "row g-3") do %>
              <%= hidden_field_tag :id, alumno.id %>
              <div class="col-md-5">
                <%= label_tag :fechaInicio, "Desde", class: "form-label" %>
                <%= date_field_tag :fechaInicio, @fechaInicio, class: "form-control" %>
              </div>
              <div class="col-md-5">
                <%= label_tag :fechaFin, "Hasta", class: "form-label" %>
                <%= date_field_tag :fechaFin, @fechaHoy, class: "form-control" %>
              </div>
              <div class="col-md-2 d-flex align-items-end">
                <%= submit_tag "Buscar", class: "btn btn-primary w-100" %>
              </div>
            <% end %>
          </div>
        </div>

      </div>
    </div>
  <% end %>
</div>

<!-- Modal para mostrar la clave generada -->
<div class="modal fade" id="claveModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Clave Generada</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-info">
          <strong>Clave generada:</strong> <span id="claveGenerada"></span>
        </div>
        <div class="mb-3">
          <label class="form-label">Mensaje para WhatsApp:</label>
          <textarea class="form-control" id="mensajeWhatsApp" rows="6" readonly></textarea>
        </div>
        <button class="btn btn-sm btn-secondary" onclick="copiarMensajeWhatsApp()">
          📋 Copiar mensaje
        </button>
        <a href="#" class="btn btn-sm btn-success" id="enviarWhatsAppBtn" style="display: none;">
          📤 Enviar por WhatsApp
        </a>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>


<script>
// Función para generar claves
document.querySelectorAll('.generar-clave-btn').forEach(btn => {
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    const alumnoId = this.dataset.alumnoId;

    if (!confirm('¿Generar una nueva clave para este alumno? La clave actual se reemplazará.')) {
      return;
    }

    // Mostrar loading
    const originalText = this.innerHTML;
    this.innerHTML = '⏳ Generando...';
    this.disabled = true;

    fetch(`/alumnos/${alumnoId}/generar_clave`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content
      }
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        // Mostrar modal con la información
        document.getElementById('claveGenerada').textContent = data.clave;
        document.getElementById('mensajeWhatsApp').value = data.mensaje_whatsapp;

        // Configurar botón de WhatsApp si hay teléfono
        const whatsappBtn = document.getElementById('enviarWhatsAppBtn');
        if (data.telefono) {
          const textoCodificado = encodeURIComponent(data.mensaje_whatsapp).replace(/\+/g, '%20');
          const telefonoLimpio = '34' + data.telefono.replace(/\D/g, '');
          whatsappBtn.href = `https://wa.me/${telefonoLimpio}?text=${textoCodificado}`;
          whatsappBtn.style.display = 'inline-block';
          
          // Añadir evento para abrir en app nativa
          whatsappBtn.onclick = function(e) {
            e.preventDefault();
            window.open(`whatsapp://send?phone=${telefonoLimpio}&text=${textoCodificado}`, '_blank');
            setTimeout(() => {
              window.open(`https://web.whatsapp.com/send?phone=${telefonoLimpio}&text=${textoCodificado}`, '_blank');
            }, 500);
          };
        } else {
          whatsappBtn.style.display = 'none';
        }

        // Mostrar modal
        new bootstrap.Modal(document.getElementById('claveModal')).show();
      } else {
        alert('Error: ' + data.error);
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Error al generar la clave');
    })
    .finally(() => {
      // Restaurar botón
      this.innerHTML = originalText;
      this.disabled = false;
    });
  });
});

function copiarMensajeWhatsApp() {
  const mensaje = document.getElementById('mensajeWhatsApp');
  mensaje.select();
  document.execCommand('copy');
  alert('Mensaje copiado al portapapeles ✅');
}

function copyToClipboard(elementId) {
  const element = document.getElementById(elementId);
  const text = element.innerText;
  navigator.clipboard.writeText(text).then(() => {
    alert("Texto copiado al portapapeles ✅");
  });
}
</script>


