<!DOCTYPE html>
<html>
  <head class="container">
    <title> <%= yield(:title) %></title>
    <meta name="description" content= <%= yield(:descripcion) %>  />
    <meta name="author" content="MiguelRodríguez de AgâraYoga" />

    <%= favicon_link_tag '/logo-agara.ico' %>

    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
            <meta property="og:title" content="Agarâra Yoga " />
            <meta property="og:url" content="http://agarayoga.eu" />
            <meta property="og:description" content= "<%= yield(:description) %>" />
            <meta property="og:image" content="https//agarayoga.eu/logo_agara_solo.png">
            <meta property="og:image:url" content="https//agarayoga.eu/logo_agara_solo.png">
            <meta property="og:image:type" content="image/png" />
            <meta property="og:image:width" content="288" />
            <meta property="og:image:height" content="246" />
            <meta property="og:image:alt" content="AgâraYoga" />

            <!-- Favicon-->
            <link rel="icon" type="image/x-icon" href="public/logo-agara.ico" />
            <%= favicon_link_tag '//agarayoga.eu/logo_agara_solo.png' %>

    <meta charset="utf-8">
    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbo-track': 'reload'%>
    <%= javascript_pack_tag 'application', 'data-turbo-track': 'reload'%>
    <script src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
  </head>

  <body class="container-fluid mt-2 ">
        <% if !notice.blank? or !alert.blank? then %>
          <div class="container-fluid mt-2">
            <%= render 'layouts/alerts' %>
          </div>
        <%end%>
        <%= yield %>

  </body>

</html>
