<% content_for :title,  "Julio-links" %>

<% Julio.all.each do |jl| %>
  <% url = asistencia_julio_url(jl.usuario_id) %>
  <% mensaje = "Hola #{jl.usuario.alias} 👋\n\nPor favor, confirma tu asistencia para julio en el siguiente enlace:\n🔗 #{url}\n\n¡Gracias por tu ayuda!" %>

  <div class="whatsapp-message mb-4 p-3 bg-light rounded">
    <% mensaje.split("\n").each do |line| %>
      <p class="mb-1"><%= line %></p>
    <% end %>
    <small class="text-muted">Enviar a: <%= jl.usuario.nombre %></small>
  </div>
<% end %>
